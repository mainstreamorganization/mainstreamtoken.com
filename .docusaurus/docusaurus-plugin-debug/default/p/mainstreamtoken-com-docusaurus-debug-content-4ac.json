 Reference","permalink":"/mainstreamtoken.com/docs/whitepaper/appendices"}},{"id":"whitepaper/ecosystem_overview","title":"Ecosystem Overview","description":"1.  Core Components:","source":"@site/docs/whitepaper/ecosystem_overview.md","sourceDirName":"whitepaper","slug":"/whitepaper/ecosystem_overview","permalink":"/mainstreamtoken.com/docs/whitepaper/ecosystem_overview","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/ecosystem_overview.md","tags":[],"version":"current","frontMatter":{},"sidebar":"whitepaper","previous":{"title":"MainstreamToken ($MAIN) Details","permalink":"/mainstreamtoken.com/docs/whitepaper/mainstreamtoken_details"},"next":{"title":"Community Engagement","permalink":"/mainstreamtoken.com/docs/whitepaper/community_engagement"}},{"id":"whitepaper/executive_summary","title":"Executive Summary","description":"MainstreamToken ($MAIN): A digital asset governed by AIDAMIS (AI Dynamic Advancement with Mainstream Innovation Synergy), an AI entity under development.","source":"@site/docs/whitepaper/executive_summary.md","sourceDirName":"whitepaper","slug":"/whitepaper/executive_summary","permalink":"/mainstreamtoken.com/docs/whitepaper/executive_summary","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/executive_summary.md","tags":[],"version":"current","frontMatter":{},"sidebar":"whitepaper","previous":{"title":"Mainstream Token Whitepaper","permalink":"/mainstreamtoken.com/docs/whitepaper/table_of_contents"},"next":{"title":"Introduction","permalink":"/mainstreamtoken.com/docs/whitepaper/introduction"}},{"id":"whitepaper/full","title":"Table of Contents","description":"*   Executive Summary","source":"@site/docs/whitepaper/full.md","sourceDirName":"whitepaper","slug":"/whitepaper/full","permalink":"/mainstreamtoken.com/docs/whitepaper/full","draft":false,"unlisted":false,"editUrl":"https://github.com/