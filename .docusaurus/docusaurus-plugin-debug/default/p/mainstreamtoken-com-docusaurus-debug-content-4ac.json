","permalink":"/mainstreamtoken.com/docs/versions/v0/parameters"},"next":{"title":"Executive Summary","permalink":"/mainstreamtoken.com/docs/whitepaper/executive_summary"}},{"id":"whitepaper/table_of_contents","title":"Mainstream Token Whitepaper","description":"⚠️ WARNING: Mainstream Token is an AI and community-driven entertainment project with no inherent financial value or guarantee of return. It operates without a formal team or roadmap and is intended for informational and entertainment purposes only.","source":"@site/docs/whitepaper/table_of_contents.mdx","sourceDirName":"whitepaper","slug":"/whitepaper/table_of_contents","permalink":"/mainstreamtoken.com/docs/whitepaper/table_of_contents","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/table_of_contents.mdx","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1},"sidebar":"whitepaper","previous":{"title":"MTL Parameters v0.1","permalink":"/mainstreamtoken.com/docs/versions/v0/parameters"},"next":{"title":"Executive Summary","permalink":"/mainstreamtoken.com/docs/whitepaper/executive_summary"}},{"id":"whitepaper/team","title":"Team","description":"Developer:","source":"@site/docs/whitepaper/team.md","sourceDirName":"whitepaper","slug":"/whitepaper/team","permalink":"/mainstreamtoken.com/docs/whitepaper/team","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/team.md","tags":[],"version":"current","frontMatter":{},"sidebar":"whitepaper","previous":{"title":"Legal and Risk Disclaimer","permalink":"/mainstreamtoken.com/docs/whitepaper/legal_disclaimer"},"next":{"title":"Conclusion","permalink":"/mainstreamtoken.com/docs/whitepaper/conclusion"}},{"id":"whitepaper/technical_appendix","title":"Technical Appendix: MainstreamToken ($MAIN) System Specifications","description":"This appendix provides technical details about the MainstreamToken (MT) system, including the data structure for on-chain storage, the hashing process, a client-side implementation focus, licensing standards, verification processes, and other technical specifications.","source":"@site/docs/whitepaper/technical_appendix.md","sourceDirName":"whitepaper","slug":"/whitepaper/technical_appendix","permalink":"/mainstreamtoken.com/docs/whitepaper/technical_appendix","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/technical_appendix.md","tags":[],"version":"current","frontMatter":{}}],"drafts":[],"sidebars":{"whitepaper":[{"type":"category","label":"License","items":[{"type":"doc","id":"license/overview"},{"type":"category","label":"v0.1","items":[{"type":"doc","id":"versions/v0/license"},{"type":"doc","id":"versions/v0/parameters"}],"collapsed":true,"collapsible":true}],"collapsed":true,"collapsible":true},{"type":"category","label":"Whitepaper","items":[{"type":"doc","id":"whitepaper/table_of_contents"},{"type":"doc","id":"whitepaper/executive_summary"},{"type":"doc","id":"whitepaper/introduction"},{"type":"doc","id":"whitepaper/aidamis"},{"type":"doc","id":"whitepaper/mainstreamtoken_details"},{"type":"doc","id":"whitepaper/ecosystem_overview"},{"type":"doc","id":"whitepaper/community_engagement"},{"type":"doc","id":"whitepaper/roadmap"},{"type":"doc","id":"whitepaper/legal_disclaimer"},{"type":"doc","id":"whitepaper/team"},{"type":"doc","id":"whitepaper/conclusion"},{"type":"doc","id":"whitepaper/appendices"}],"collapsed":true,"collapsible":true},{"type":"category","label":"Tutorial","items":[{"type":"doc","id":"tutorial/encoder-decoder"},{"type":"doc","id":"tutorial/buy-mt-tokens"}],"collapsed":true,"collapsible":true}]}}]}},"docusaurus-plugin-content-blog":{"default":{"blogSidebarTitle":"Recent posts","blogPosts":[{"id":"launch-announcement","metadata":{"permalink":"/mainstreamtoken.com/news/launch-announcement","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/news/2025-01-01-launch-announcement.mdx","source":"@site/news/2025-01-01-launch-announcement.mdx","title":"A Birthday Gift to Crypto: Mainstream Token Launches on Bitcoin's Anniversary","description":"In a symbolic nod to the cryptocurrency that started it all, Mainstream Token ($MAIN) has chosen January 3rd, 2024 - Bitcoin's 15th birthday - for its official launch on the pump.fun platform.","date":"2025-01-01T00:00:00.000Z","tags":[{"inline":true,"label":"launch","permalink":"/mainstreamtoken.com/news/tags/launch"},{"inline":true,"label":"announcement","permalink":"/mainstreamtoken.com/news/tags/announcement"},{"inline":true,"label":"bitcoin","permalink":"/mainstreamtoken.com/news/tags/bitcoin"}],"readingTime":0.84,"hasTruncateMarker":false,"authors":[{"name":"Mainstream Team","title":"Core Team","url":"https://github.com/mainstreamorganization","imageURL":"https://github.com/mainstreamorganization.png","key":"mainstream","page":null}],"frontMatter":{"slug":"launch-announcement","title":"A Birthday Gift to Crypto: Mainstream Token Launches on Bitcoin's Anniversary","authors":["mainstream"],"tags":["launch","announcement","bitcoin"]},"unlisted":false,"nextItem":{"title":"Community Update - December 2024","permalink":"/mainstreamtoken.com/news/community-update-dec-2024"}},"content":"In a symbolic nod to the cryptocurrency that started it all, Mainstream Token ($MAIN) has chosen January 3rd, 2024 - Bitcoin's 15th birthday - for its official launch on the pump.fun platform.\n\n## Why January 3rd Matters\n\nOn January 3rd, 2009, Satoshi Nakamoto mined Bitcoin's genesis block, marking the birth of cryptocurrency. Fifteen years later, we're honoring this revolutionary moment by launching Mainstream Token, a project that aims to bridge the gap between human and artificial intelligence in the crypto space.\n\n## Launch Details\n\n- **Platform**: pump.fun\n- **Date**: January 3rd, 2024\n- **Token**: $MAIN (Mainstream Token)\n- **Blockchain**: Solana\n\nJoin us as we write the next chapter in cryptocurrency history. The launch coincides with Bitcoin's birthday as a tribute to the innovation and decentralization principles that Bitcoin introduced to the world.\n\nStay tuned for more details and join our community channels to participate in this historic launch.\n\n*\"In the spirit of Bitcoin's birthday, we're launching a token that represents the mainstream adoption of cryptocurrency and AI integration.\"*"},{"id":"community-update-dec-2024","metadata":{"permalink":"/mainstreamtoken.com/news/community-update-dec-2024","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/news/2024-12-19-community-update.mdx","source":"@site/news/2024-12-19-community-update.mdx","title":"Community Update - December 2024","description":"A community update for Mainstream Token","date":"2024-12-20T00:00:00.000Z","tags":[{"inline":true,"label":"community","permalink":"/mainstreamtoken.com/news/tags/community"},{"inline":true,"label":"update","permalink":"/mainstreamtoken.com/news/tags/update"},{"inline":true,"label":"mainstreamtoken","permalink":"/mainstreamtoken.com/news/tags/mainstreamtoken"},{"inline":true,"label":"blockchain","permalink":"/mainstreamtoken.com/news/tags/blockchain"}],"readingTime":0.695,"hasTruncateMarker":false,"authors":[{"name":"Mainstream Team","title":"Core Team","url":"https://github.com/mainstreamorganization","imageURL":"https://github.com/mainstreamorganization.png","key":"mainstream","page":null}],"frontMatter":{"title":"Community Update - December 2024","description":"A community update for Mainstream Token","slug":"community-update-dec-2024","authors":["mainstream"],"tags":["community","update","mainstreamtoken","blockchain"],"date":"2024-12-20T00:00:00.000Z"},"unlisted":false,"prevItem":{"title":"A Birthday Gift to Crypto: Mainstream Token Launches on Bitcoin's Anniversary","permalink":"/mainstreamtoken.com/news/launch-announcement"},"nextItem":{"title":"AI Integration in Mainstream Token","permalink":"/mainstreamtoken.com/news/ai-integration"}},"content":"Hello Mainstream Token community!\n\nWe're excited to share some updates on the project's progress and future plans.\n\n## Recent Developments\n\n-   **MTL Protocol Implementation:** We've successfully implemented the core features of the MTL Protocol.\n-   **Community Feedback:** We've gathered valuable feedback from the community and are working on improvements.\n-   **Documentation Updates:** We've updated our documentation to reflect the latest changes.\n\n## Future Plans\n\n-   **Community Governance:** We're exploring options for implementing community governance mechanisms.\n-   **Partnerships:** We're actively seeking partnerships to expand the reach of the MTL Protocol.\n-   **New Features:** We're planning to add new features to the MTL Protocol based on community feedback.\n\n## Get Involved\n\nWe encourage all community members to get involved in the project. Share your ideas, provide feedback, and help us shape the future of Mainstream Token.\n\nStay tuned for more updates!"},{"id":"ai-integration","metadata":{"permalink":"/mainstreamtoken.com/news/ai-integration","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/news/2024-12-20-ai-integration.mdx","source":"@site/news/2024-12-20-ai-integration.mdx","title":"AI Integration in Mainstream Token","description":"Exploring the role of AI in Mainstream Token","date":"2024-12-19T00:00:00.000Z","tags":[{"inline":true,"label":"ai","permalink":"/mainstreamtoken.com/news/tags/ai"},{"inline":true,"label":"integration","permalink":"/mainstreamtoken.com/news/tags/integration"},{"inline":true,"label":"mainstreamtoken","permalink":"/mainstreamtoken.com/news/tags/mainstreamtoken"},{"inline":true,"label":"blockchain","permalink":"/mainstreamtoken.com/news/tags/blockchain"}],"readingTime":0.76,"hasTruncateMarker":false,"authors":[{"name":"Mainstream Team","title":"Core Team","url":"https://github.com/mainstreamorganization","imageURL":"https://github.com/mainstreamorganization.png","key":"mainstream","page":null}],"frontMatter":{"title":"AI Integration in Mainstream Token","description":"Exploring the role of AI in Mainstream Token","slug":"ai-integration","authors":["mainstream"],"tags":["ai","integration","mainstreamtoken","blockchain"],"date":"2024-12-19T00:00:00.000Z"},"unlisted":false,"prevItem":{"title":"Community Update - December 2024","permalink":"/mainstreamtoken.com/news/community-update-dec-2024"},"nextItem":{"title":"Welcome to Mainstream Token","permalink":"/mainstreamtoken.com/news/welcome"}},"content":"We're excited to share our plans for integrating AI into the Mainstream Token ecosystem.\n\n## AI-Driven Governance\n\nWe believe that AI can play a crucial role in community governance. We're exploring options for using AI to:\n\n-   **Analyze Community Feedback:** Identify trends and patterns in community feedback.\n-   **Automate Decision Making:** Automate certain decision-making processes based on predefined rules.\n-   **Improve Efficiency:** Improve the efficiency of the governance process.\n\n## AI-Powered Content Creation\n\nWe're also exploring the use of AI to assist with content creation. This could include:\n\n-   **Generating Content:** Using AI to generate content for the community.\n-   **Improving Content Quality:** Using AI to improve the quality of content.\n-   **Personalizing Content:** Using AI to personalize content for individual users.\n\n## Future Plans\n\nWe're committed to exploring the full potential of AI in the Mainstream Token ecosystem. We'll continue to share updates on our progress.\n\nStay tuned for more updates!"},{"id":"welcome","metadata":{"permalink":"/mainstreamtoken.com/news/welcome","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/news/2024-12-18-welcome.md","source":"@site/news/2024-12-18-welcome.md","title":"Welcome to Mainstream Token","description":"We're excited to announce the launch of Mainstream Token - an AI-powered cryptocurrency community token designed to revolutionize digital asset management.","date":"2024-12-18T00:00:00.000Z","tags":[{"inline":false,"label":"Hello","permalink":"/mainstreamtoken.com/news/tags/hello","description":"Hello tag description"},{"inline":true,"label":"mainstream","permalink":"/mainstreamtoken.com/news/tags/mainstream"}],"readingTime":0.2,"hasTruncateMarker":false,"authors":[{"name":"Mainstream Team","title":"Core Team","url":"https://github.com/mainstreamorganization","imageURL":"https://github.com/mainstreamorganization.png","key":"mainstream","page":null}],"frontMatter":{"slug":"welcome","title":"Welcome to Mainstream Token","authors":["mainstream"],"tags":["hello","mainstream"]},"unlisted":false,"prevItem":{"title":"AI Integration in Mainstream Token","permalink":"/mainstreamtoken.com/news/ai-integration"},"nextItem":{"title":"Mainstream Token License Protocol Launch","permalink":"/mainstreamtoken.com/news/mtl-launch"}},"content":"We're excited to announce the launch of Mainstream Token - an AI-powered cryptocurrency community token designed to revolutionize digital asset management.\n\n## What's Next?\n\nStay tuned for more updates as we continue to develop our platform and grow our community."},{"id":"mtl-launch","metadata":{"permalink":"/mainstreamtoken.com/news/mtl-launch","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/news/2024-12-19-mtl-launch.mdx","source":"@site/news/2024-12-19-mtl-launch.mdx","title":"Mainstream Token License Protocol Launch","description":"Announcing the launch of the Mainstream Token License Protocol","date":"2024-12-18T00:00:00.000Z","tags":[{"inline":true,"label":"mtl","permalink":"/mainstreamtoken.com/news/tags/mtl"},{"inline":true,"label":"launch","permalink":"/mainstreamtoken.com/news/tags/launch"},{"inline":true,"label":"protocol","permalink":"/mainstreamtoken.com/news/tags/protocol"},{"inline":true,"label":"mtlprotocol","permalink":"/mainstreamtoken.com/news/tags/mtlprotocol"},{"inline":true,"label":"digitalrights","permalink":"/mainstreamtoken.com/news/tags/digitalrights"},{"inline":true,"label":"blockchain","permalink":"/mainstreamtoken.com/news/tags/blockchain"}],"readingTime":0.81,"hasTruncateMarker":false,"authors":[{"name":"Mainstream Team","title":"Core Team","url":"https://github.com/mainstreamorganization","imageURL":"https://github.com/mainstreamorganization.png","key":"mainstream","page":null}],"frontMatter":{"title":"Mainstream Token License Protocol Launch","description":"Announcing the launch of the Mainstream Token License Protocol","slug":"mtl-launch","authors":["mainstream"],"tags":["mtl","launch","protocol","mtlprotocol","digitalrights","blockchain"],"date":"2024-12-18T00:00:00.000Z"},"unlisted":false,"prevItem":{"title":"Welcome to Mainstream Token","permalink":"/mainstreamtoken.com/news/welcome"}},"content":"We are thrilled to announce the launch of the Mainstream Token License (MTL) Protocol! This marks a significant milestone in our journey to revolutionize digital rights management.\n\n## What is the MTL Protocol?\n\nThe MTL Protocol is a parameter-based system that uses MT tokens to define specific rights and parameters for digital assets. It allows creators to specify the terms of use for their content, and provides a transparent verification system for digital rights.\n\n## Key Features\n\n-   **Parameter-Based Licenses:** Define licenses with specific parameters such as usage rights, duration, and geographic restrictions.\n-   **Token Ownership Verification:** Access to digital assets is verified through ownership of MT tokens.\n-   **Transparent System:** All license parameters and ownership details are recorded on the blockchain.\n-   **Revenue Distribution:** Facilitates revenue distribution to content creators based on license usage.\n\n## How to Get Started\n\nVisit our documentation to learn more about the MTL Protocol and how to create and manage licenses.\n\nStay tuned for more updates!"}],"blogListPaginated":[{"items":["launch-announcement","community-update-dec-2024","ai-integration","welcome","mtl-launch"],"metadata":{"permalink":"/mainstreamtoken.com/news","page":1,"postsPerPage":10,"totalPages":1,"totalCount":5,"blogDescription":"Blog","blogTitle":"Blog"}}],"blogTags":{"/mainstreamtoken.com/news/tags/launch":{"inline":true,"label":"launch","permalink":"/mainstreamtoken.com/news/tags/launch","items":["launch-announcement","mtl-launch"],"pages":[{"items":["launch-announcement","mtl-launch"],"metadata":{"permalink":"/mainstreamtoken.com/news/tags/launch","page":1,"postsPerPage":10,"totalPages":1,"totalCount":2,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mainstreamtoken.com/news/tags/announcement":{"inline":true,"label":"announcement","permalink":"/mainstreamtoken.com/news/tags/announcement","items":["launch-announcement"],"pages":[{"items":["launch-announcement"],"metadata":{"permalink":"/mainstreamtoken.com/news/tags/announcement","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mainstreamtoken.com/news/tags/bitcoin":{"inline":true,"label":"bitcoin","permalink":"/mainstreamtoken.com/news/tags/bitcoin","items":["launch-announcement"],"pages":[{"items":["launch-announcement"],"metadata":{"permalink":"/mainstreamtoken.com/news/tags/bitcoin","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mainstreamtoken.com/news/tags/community":{"inline":true,"label":"community","permalink":"/mainstreamtoken.com/news/tags/community","items":["community-update-dec-2024"],"pages":[{"items":["community-update-dec-2024"],"metadata":{"permalink":"/mainstreamtoken.com/news/tags/community","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mainstreamtoken.com/news/tags/update":{"inline":true,"l