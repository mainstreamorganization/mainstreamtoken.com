{"allContent":{"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/mainstreamtoken.com/docs","tagsPath":"/mainstreamtoken.com/docs/tags","editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs","editUrlLocalized":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/i18n/en/docusaurus-plugin-content-docs/current","isLast":true,"routePriority":-1,"sidebarFilePath":"/usr/local/src/mainstreamtoken.com123/sidebars.ts","contentPath":"/usr/local/src/mainstreamtoken.com123/docs","contentPathLocalized":"/usr/local/src/mainstreamtoken.com123/i18n/en/docusaurus-plugin-content-docs/current","docs":[{"id":"license/overview","title":"MTL Experimental Protocol Overview","description":"The Mainstream Token License (MTL) experimental protocol is a decentralized digital rights management system. It allows creators to define specific usage rights and parameters for their digital assets, which can be enforced through various methods, including but not limited to the Mainstream Token ($MAIN) on the Solana blockchain, user-created smart contracts, other blockchains, or even without a blockchain where any form of payment is accepted.","source":"@site/docs/license/overview.md","sourceDirName":"license","slug":"/license/overview","permalink":"/mainstreamtoken.com/docs/license/overview","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/license/overview.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1},"sidebar":"whitepaper","next":{"title":"MTL License v0.1","permalink":"/mainstreamtoken.com/docs/versions/v0/license"}},{"id":"license/parameters","title":"MTL License Parameters","description":"The Mainstream Token License (MTL) protocol uses a parameter-based system to define the terms of a license. These parameters are encoded into a unique MTL string, which is then used to verify access to the licensed digital asset.","source":"@site/docs/license/parameters.md","sourceDirName":"license","slug":"/license/parameters","permalink":"/mainstreamtoken.com/docs/license/parameters","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/license/parameters.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2}},{"id":"license/payment","title":"MTL License Payment","description":"The Mainstream Token License (MTL) protocol facilitates secure and transparent payments for access to licensed digital assets. This process ensures that creators receive fair compensation for their work and that users can access content with confidence.","source":"@site/docs/license/payment.md","sourceDirName":"license","slug":"/license/payment","permalink":"/mainstreamtoken.com/docs/license/payment","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/license/payment.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4}},{"id":"license/verification","title":"MTL License Verification","description":"The Mainstream Token License (MTL) protocol uses a transparent and secure verification process to ensure that only authorized users can access licensed digital assets. This process involves checking the user's ownership of Mainstream Tokens (MT) and verifying the license parameters encoded in the MTL string.","source":"@site/docs/license/verification.md","sourceDirName":"license","slug":"/license/verification","permalink":"/mainstreamtoken.com/docs/license/verification","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/license/verification.md","tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3}},{"id":"license/versions/v0","title":"MTL Experimental Protocol Version 0 (v0)","description":"This document outlines the specifications for version 0 of the Mainstream Token License (MTL) experimental protocol. This version introduces the core features of the MTL experimental protocol, including parameter-based licensing, token-based verification, and revenue distribution.","source":"@site/docs/license/versions/v0.md","sourceDirName":"license/versions","slug":"/license/versions/v0","permalink":"/mainstreamtoken.com/docs/license/versions/v0","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/license/versions/v0.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4}},{"id":"tokenomics/distribution","title":"Token Distribution","description":"The MainstreamToken (MT) distribution is structured to ensure long-term sustainability and balanced allocation across key stakeholders:","source":"@site/docs/tokenomics/distribution.md","sourceDirName":"tokenomics","slug":"/tokenomics/distribution","permalink":"/mainstreamtoken.com/docs/tokenomics/distribution","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/tokenomics/distribution.md","tags":[],"version":"current","frontMatter":{}},{"id":"tutorial/buy-mt-tokens","title":"How to Buy Mainstream Tokens ($MAIN)","description":"This tutorial will guide you through the process of purchasing Mainstream Tokens ($MAIN) to support the project.","source":"@site/docs/tutorial/buy-mt-tokens.md","sourceDirName":"tutorial","slug":"/tutorial/buy-mt-tokens","permalink":"/mainstreamtoken.com/docs/tutorial/buy-mt-tokens","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/tutorial/buy-mt-tokens.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4},"sidebar":"whitepaper","previous":{"title":"Using the MTL Encoder and Decoder","permalink":"/mainstreamtoken.com/docs/tutorial/encoder-decoder"}},{"id":"tutorial/encoder-decoder","title":"Using the MTL Encoder and Decoder","description":"Learn how to use the MTL Encoder and Decoder apps to create and verify license strings","source":"@site/docs/tutorial/encoder-decoder.md","sourceDirName":"tutorial","slug":"/tutorial/encoder-decoder","permalink":"/mainstreamtoken.com/docs/tutorial/encoder-decoder","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/tutorial/encoder-decoder.md","tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Using the MTL Encoder and Decoder","description":"Learn how to use the MTL Encoder and Decoder apps to create and verify license strings"},"sidebar":"whitepaper","previous":{"title":"Appendices & Reference","permalink":"/mainstreamtoken.com/docs/whitepaper/appendices"},"next":{"title":"How to Buy Mainstream Tokens ($MAIN)","permalink":"/mainstreamtoken.com/docs/tutorial/buy-mt-tokens"}},{"id":"versions/v0/license","title":"MTL License v0.1","description":"The complete MainstreamToken License Version 0.1 is provided below. You can find the full technical specifications and parameters in the Version v0.1 section.","source":"@site/docs/versions/v0/license.md","sourceDirName":"versions/v0","slug":"/versions/v0/license","permalink":"/mainstreamtoken.com/docs/versions/v0/license","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/versions/v0/license.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4,"title":"MTL License v0.1"},"sidebar":"whitepaper","previous":{"title":"MTL Experimental Protocol Overview","permalink":"/mainstreamtoken.com/docs/license/overview"},"next":{"title":"MTL Parameters v0.1","permalink":"/mainstreamtoken.com/docs/versions/v0/parameters"}},{"id":"versions/v0/parameters","title":"MTL Parameters v0.1","description":"This document provides the technical details, and is intended for developers and other users, and is a part of the above license.","source":"@site/docs/versions/v0/parameters.md","sourceDirName":"versions/v0","slug":"/versions/v0/parameters","permalink":"/mainstreamtoken.com/docs/versions/v0/parameters","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/versions/v0/parameters.md","tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"sidebar_position":5,"title":"MTL Parameters v0.1"},"sidebar":"whitepaper","previous":{"title":"MTL License v0.1","permalink":"/mainstreamtoken.com/docs/versions/v0/license"},"next":{"title":"Mainstream Token Whitepaper","permalink":"/mainstreamtoken.com/docs/whitepaper/table_of_contents"}},{"id":"whitepaper/aidamis","title":"AIDAMIS Framework (Under Development)","description":"(Artificial Intelligence Directive for Autonomous Management and Insight Strategy)","source":"@site/docs/whitepaper/aidamis.md","sourceDirName":"whitepaper","slug":"/whitepaper/aidamis","permalink":"/mainstreamtoken.com/docs/whitepaper/aidamis","draft":false,"unlisted":false,"editUrl":"https://github.com/mainstreamorganization/mainstreamtoken/tree/main/docs/whitepaper/aidamis.md","tags":[],"version":"current","frontMatter":{},"sidebar":"whitepaper","previous":{"title":"Introduction","permalink":"/mainstreamtoken.com/docs/whitepaper/introduction"},"next":{"title":"MainstreamToken ($MAIN) Details","permalink":"/mainstreamtoken.com/docs/whitepaper/mainstreamtoken_details"}},{"id":"whitepaper/appendices","title":"Appendices & Reference","description":"This section provides supplementary information and references to support the main content of the MainstreamToken (MT) whitepaper.","source":"@site/docs/whitepaper/appendices.md","sourceDirName":"whitepaper","slug":"/whitepaper/appendices","permalink":"/mainstreamtoken.com/docs/whitepaper/appendices","draft":fals