# 2024-12-18 17:07:01.010053
+with reference to the below javascript code, add to the header section where "Mainstream Token" begins inside to be used as background effect without any margin: <!DOCTYPE html>
+<html>
+<head>
+    <style>
+        .header-container {
+            position: relative;
+            height: 100%;
+            width: 100%;
+            overflow: hidden;
+            display: flex;
+            align-items: center;
+            justify-content: center;
+        }
+
+        canvas {
+            position: absolute;
+            top: 0;
+            left: 0;
+            z-index: 1;
+            width: 100%;
+            height: 100%;
+        }
+
+        .header-content {
+            position: relative;
+            z-index: 2;
+            color: black;
+            text-align: center;
+            font-family: Arial, sans-serif;
+        }
+
+        body {
+            margin: 0;
+            height: 100vh;
+        }
+    </style>
+</head>
+<body>
+    <div class="header-container">
+        <canvas id="neural"></canvas>
+        <div class="header-content">
+            <h1>Content Goes Here</h1>
+            <p>Your content will appear on top of the effect</p>
+        </div>
+    </div>
+
+    <script>
+        const canvas = document.getElementById('neural');
+        const ctx = canvas.getContext('2d');
+
+        function resize() {
+            const container = document.querySelector('.header-container');
+            canvas.width = container.offsetWidth;
+            canvas.height = container.offsetHeight;
+        }
+        resize();
+        window.addEventListener('resize', resize);
+
+        function getColorPalette() {
+            const palettes = [
+                { hue: Math.random() * 360, sat: 70, light: 60 },
+                { hue: (Math.random() * 60 + 180), sat: 80, light: 50 },
+                { hue: (Math.random() * 60 + 300), sat: 75, light: 55 },
+                { hue: (Math.random() * 60), sat: 75, light: 55 },
+            ];
+            return palettes[Math.floor(Math.random() * palettes.length)];
+        }
+
+        class Particle {
+            constructor() {
+                this.reset();
+            }
+
+            reset() {
+                this.x = Math.random() * canvas.width;
+                this.y = Math.random() * canvas.height;
+                this.vx = (Math.random() - 0.5) * 1.5;
+                this.vy = (Math.random() - 0.5) * 1.5;
+                this.radius = Math.random() * 1.5 + 0.5;
+                const palette = getColorPalette();
+                this.hue = palette.hue;
+                this.sat = palette.sat;
+                this.light = palette.light;
+                this.colorChangeSpeed = Math.random() * 0.5 + 0.1;
+            }
+
+            update() {
+                this.x += this.vx;
+                this.y += this.vy;
+
+                if (this.x < 0 || this.x > canvas.width) {
+                    this.vx *= -1;
+                    const palette = getColorPalette();
+                    this.hue = palette.hue;
+                }
+                if (this.y < 0 || this.y > canvas.height) {
+                    this.vy *= -1;
+                    const palette = getColorPalette();
+                    this.hue = palette.hue;
+                }
+
+                this.hue += this.colorChangeSpeed;
+                if (this.hue > 360) this.hue = 0;
+            }
+
+            draw() {
+                ctx.beginPath();
+                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
+                ctx.fillStyle = `hsla(${this.hue}, ${this.sat}%, ${this.light}%, 0.9)`; // 90% opacity
+                ctx.fill();
+            }
+        }
+
+        const particles = Array.from({ length: 80 }, () => new Particle()); // Doubled number of particles
+
+        function animate() {
+            // Clear canvas with fully transparent background
+            ctx.clearRect(0, 0, canvas.width, canvas.height);
+
+            particles.forEach(particle => {
+                particle.update();
+                particle.draw();
+
+                particles.forEach(other => {
+                    if (particle === other) return;
+
+                    const dx = particle.x - other.x;
+                    const dy = particle.y - other.y;
+                    const distance = Math.sqrt(dx * dx + dy * dy);
+
+                    if (distance < 150) { // Increased connection distance
+                        ctx.beginPath();
+                        ctx.moveTo(particle.x, particle.y);
+                        ctx.lineTo(other.x, other.y);
+
+                        const opacity = 1 - (distance / 100);
+                        const avgHue = (particle.hue + other.hue) / 2;
+                        
+                        // More transparent connections
+                        ctx.strokeStyle = `hsla(${avgHue}, 85%, 60%, ${opacity * 0.4})`; // More intense lines
+                        ctx.lineWidth = 1.0; // Thicker lines
+                        ctx.stroke();
+
+                        // More intense pulse effect
+                        const pulseSize = Math.sin(Date.now() * 0.004) * 2 + 3;
+                        ctx.beginPath();
+                        ctx.arc(
+                            (particle.x + other.x) / 2,
+                            (particle.y + other.y) / 2,
+                            pulseSize,
+                            0,
+                            Math.PI * 2
+                        );
+                        ctx.fillStyle = `hsla(${avgHue}, 85%, 60%, ${opacity * 0.3})`;
+                        ctx.fill();
+                    }
+                });
+            });
+
+            requestAnimationFrame(animate);
+        }
+
+        animate();
+    </script>
+</body>
+</html>

